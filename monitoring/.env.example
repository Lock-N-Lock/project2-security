# monitoring/.env.example


# Setup
# cd ~/project2-security
# cp monitoring/.env.example monitoring/.env
# vi monitoring/.env


# Notes

# - monitoring/.env 는 Git에 커밋하지 않습니다.
# - 이 파일(.env.example)은 예시 템플릿 용도로만 사용합니다.
# - 실제 인증 정보(API Key, Bot Token, AWS Key)는 monitoring/.env 에만 저장합니다.
# - 값 변경 후 monitoring stack 재시작이 필요할 수 있습니다.


# -------------------------------------------------------------------------

# Tailscale
# tailscale-sd가 App / DB 노드를 조회하는 데 사용합니다.
# Access Token은 기본적으로 만료 기간(90일)이 있으며,
# 만료 또는 권한 변경 시 tailscale-sd 대상 조회가 실패할 수 있습니다.

# -------------------------------------------------------------------------

# Tailscale API Access Token

TS_API_KEY=tskey-api-xxxx

# Tailnet Name

# "-" 사용 시 토큰 소유자의 기본 Tailnet 사용

TS_TAILNET=-

# -------------------------------------------------------------------------

# Telegram
# Alert 및 Recovery Notification 발송에 사용합니다.

# -------------------------------------------------------------------------

# Telegram Bot Token

TELEGRAM_BOT_TOKEN=

# Telegram Chat ID

TELEGRAM_CHAT_ID=

# -------------------------------------------------------------------------

# AWS CloudWatch
# Grafana CloudWatch Dashboard 및 AWS 모니터링에 사용합니다.

# -------------------------------------------------------------------------

# AWS Access Key ID
AWS_ACCESS_KEY_ID=

# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=

# AWS Region
AWS_DEFAULT_REGION=ap-northeast-2

# CloudWatch 리소스 이름
# bootstrap_monitoring.sh가 아래 이름을 사용하여
# CloudWatch Dimension 값을 자동 생성합니다.