# ======================================================================
# terraform.tfvars.example — 복사해서 terraform.tfvars 로 사용
# terraform.tfvars 는 .gitignore 로 커밋 제외됨
# 파일위치 : ~/project2-security/infra/terraform/terraform.tfvars.example
# ======================================================================

# ── 공통 ──
project    = "lb"
aws_region = "ap-northeast-2"
key_name   = "lb-key"

# 본인 공인 IP 로 좁히기 (curl ifconfig.me 로 확인)
admin_ingress_cidr = "1.2.3.4/32"

# ── HTTPS / DNS ──
enable_https = true

# [팀원] Route53 사용 시:
dns_provider      = "route53"
domain_name       = "lockbank.example.com"
route53_zone_name = "example.com"

# [신준한] Cloudflare 사용 시:
# dns_provider       = "cloudflare"
# domain_name        = "lockbank.junhanshin.com"
# cloudflare_zone_id = "여기에_Cloudflare_Zone_ID"
# cloudflare_api_token 은 tfvars 에 넣지 말 것!
#   → export TF_VAR_cloudflare_api_token="cf_xxx"

# ── Tailscale ──
tailnet_name      = "your-email@gmail.com"          # ◀ 여기에 ~/.tailscale_key 의 'TAILNET_NAME' 값을 붙여넣으세요!
tailscale_api_key = "tskey-api-your-api-key-here" # # ◀ 여기에 ~/.tailscale_key 의 'TAILSCALE_API_KEY' 값을 붙여넣으세요!